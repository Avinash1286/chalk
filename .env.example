# Next.js frontend Convex endpoint, e.g. https://your-deployment.convex.cloud.
# Existing VITE_CONVEX_URL is also supported by app/page.tsx for local migration.
NEXT_PUBLIC_CONVEX_URL=
VITE_CONVEX_URL=

# Worker Convex endpoint. Usually same value without the VITE_ prefix.
# If omitted, the local worker falls back to VITE_CONVEX_URL.
CONVEX_URL=

# Showcase / portfolio mode. Set to "off" to DISABLE video generation in the
# frontend (no worker or GCP needed): any generate/resume/regenerate attempt
# shows a toast and routes the visitor to the gallery of existing videos.
# Leave unset (or any other value) to enable generation normally.
NEXT_PUBLIC_DEMO=

# Optional bearer token if your HTTP actions/mutations require auth.
CONVEX_AUTH_TOKEN=

# Google Cloud / Vertex AI
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# Path to a Vertex AI service-account JSON key. KEEP THIS FILE OUTSIDE THE REPO.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# --- AI models (every model id is read from these env vars) ---
VERTEX_LOCATION=global
# Main reasoning model: director (outline), parallel scene designers, script editor.
GEMINI_MODEL=gemini-3.5-flash
# Context-aware icon reranker (a fast/cheap Gemini model is ideal).
RERANK_MODEL=gemini-3.5-flash
# Multimodal completed-scene critic. Defaults to GEMINI_MODEL.
SCENE_QA_MODEL=gemini-3.5-flash
# Image model that draws the house icon library (scripts/generate-icon-library.ts
# + the runtime long-tail fallback when no icon matches a concept).
ICON_IMAGE_MODEL=gemini-3.1-flash-lite-image
# Text embeddings for icon search. MUST match the model the prebuilt embedding
# indexes were built with (re-run the asset:embeddings scripts if you change it).
EMBED_MODEL=gemini-embedding-001
VERTEX_EMBED_LOCATION=us-central1

# Text-to-Speech
GOOGLE_TTS_VOICE=en-US-Chirp3-HD-Charon
GOOGLE_TTS_LANGUAGE=en-US

# Rendering (1080p default; set 1280x720 for faster preview renders)
VIDEO_WIDTH=1920
VIDEO_HEIGHT=1080
VIDEO_FPS=12

# --- Optional tuning ---
# GEMINI_TIMEOUT_MS=90000        # per LLM call timeout
# TTS_TIMEOUT_MS=120000
# SCENE_DESIGN_CONCURRENCY=5     # parallel scene-designer agents
# SCENE_VISUAL_QA=off            # disable multimodal still review + selective repair
# RERANK_SKIP_ABOVE=0.9          # skip rerank when a match is this confident
# EMBED_DELAY_MS=3000            # pacing between embedding batches (quota)
